generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  name             String?
  image            String?
  hashedPassword   String?
  bio              String?                  @db.VarChar(500)
  points           Int                      @default(0)
  level            Int                      @default(1)
  role             String                   @default("member")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  searchVector     Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(name, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, (COALESCE(bio, ''::character varying))::text), 'B'::\"char\"))"))
  languageCode     String?                  @default("en") @db.VarChar(10)
  jobDescription   String?                  @db.VarChar(100)
  stripeCustomerId String?                  @unique
  auditLogs        AuditLog[]
  bannedUsers      Ban[]                    @relation("BannedByUser")
  bans             Ban[]                    @relation("UserBans")
  comments         Comment[]
  commentLikes     CommentLike[]
  devResources     DevTrackerResource[]
  enrollments      Enrollment[]
  events           Event[]
  lessonProgress   LessonProgress[]
  membership       Membership?
  pointsEvents     PointsEvent[]
  posts              Post[]
  postLikes          PostLike[]
  featureIdeas       FeatureIdea[]        @relation("FeatureIdeaAuthor")
  featureIdeaUpvotes FeatureIdeaUpvote[]  @relation("FeatureIdeaUpvotes")
  featureIdeaComments FeatureIdeaComment[] @relation("FeatureIdeaComments")
  kanbanCards        KanbanCard[]
  blacklistEntries   TranslationBlacklist[] @relation("BlacklistAddedBy")
  glossaryApprovals  TranslationGlossaryEntry[] @relation("GlossaryApprovedBy")
  glossaryChanges    GlossaryChangeLog[] @relation("GlossaryChangeBy")
  translationFeedback TranslationFeedback[] @relation("TranslationFeedbackUser")
  resolvedFeedback   TranslationFeedback[] @relation("FeedbackResolvedBy")
  emailNotifications    Boolean @default(true)
  notificationsReceived Notification[] @relation("NotificationRecipient")
  notificationsSent     Notification[] @relation("NotificationActor")
  badges                Badge[]
  currentStreak         Int       @default(0)
  longestStreak         Int       @default(0)
  lastActivityDate      DateTime?
  freezeTokens          Int       @default(0)
  lastEmailDigestAt     DateTime?
  activationChecklistDismissedAt DateTime?
  // CR9 F2: Cross-device theme preference. Nullable so a future "system" option can NULL without a second migration.
  themePreference       String?    @default("dark") @db.VarChar(10)

  @@index([email])
  @@index([points])
  @@index([searchVector], type: Gin)
}

model Category {
  id          String   @id @default(cuid())
  name        String   @unique
  color       String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  posts       Post[]
}

model Post {
  id           String                   @id @default(cuid())
  content      Json
  plainText    String?
  embeds       Json                     @default("[]")
  authorId     String
  categoryId   String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  searchVector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, COALESCE(\"plainText\", ''::text))"))
  title        String?                  @db.VarChar(200)
  languageCode String?                  @db.VarChar(10)
  contentHash  String?                  @db.VarChar(64)
  gifs         Json                     @default("[]")
  gifThumbnails Json                     @default("[]")
  comments      Comment[]
  author        User                     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category      Category?                @relation(fields: [categoryId], references: [id])
  likes         PostLike[]
  notifications Notification[]

  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt(sort: Desc)])
  @@index([categoryId, createdAt(sort: Desc)])
  @@index([searchVector], type: Gin)
}

model Comment {
  id           String        @id @default(cuid())
  content      String        @db.VarChar(2000)
  authorId     String
  postId       String
  parentId     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contentHash  String?
  languageCode String?
  author        User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post          Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  parent        Comment?      @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies       Comment[]     @relation("CommentReplies")
  likes         CommentLike[]
  notifications Notification[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
  @@index([createdAt(sort: Desc)])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@index([email])
  @@index([token])
}

model Course {
  id           String                   @id @default(cuid())
  title        String
  description  String?
  status       CourseStatus             @default(DRAFT)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  searchVector Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(title, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(description, ''::text)), 'B'::\"char\"))"))
  languageCode String?                  @db.VarChar(10)
  contentHash  String?                  @db.VarChar(64)
  coverImage   String?
  enrollments  Enrollment[]
  modules      Module[]

  @@index([status])
  @@index([searchVector], type: Gin)
}

model Module {
  id        String   @id @default(cuid())
  title     String
  position  Int
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([courseId, position])
}

model Lesson {
  id           String           @id @default(cuid())
  title        String
  position     Int
  status       LessonStatus     @default(DRAFT)
  videoUrl     String?
  content      Json
  moduleId     String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  languageCode String?          @db.VarChar(10)
  contentHash  String?          @db.VarChar(64)
  attachments  Attachment[]
  module       Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]

  @@index([moduleId])
  @@index([moduleId, position])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int
  mimeType  String
  lessonId  String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Event {
  id            String         @id @default(cuid())
  title         String         @db.VarChar(200)
  description   Json
  startTime     DateTime       @db.Timestamptz(3)
  endTime       DateTime       @db.Timestamptz(3)
  location      String?        @db.VarChar(200)
  locationUrl   String?        @db.VarChar(500)
  coverImage    String?
  recurrence    RecurrenceType @default(NONE)
  recurrenceEnd DateTime?      @db.Timestamptz(3)
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  languageCode  String?        @db.VarChar(10)
  contentHash   String?        @db.VarChar(64)
  createdBy     User           @relation(fields: [createdById], references: [id])

  @@index([startTime])
  @@index([createdById])
}

model PointsEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  action    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Ban {
  id         String    @id @default(cuid())
  userId     String
  reason     String    @db.VarChar(500)
  expiresAt  DateTime? @db.Timestamptz(3)
  bannedById String
  createdAt  DateTime  @default(now())
  bannedBy   User      @relation("BannedByUser", fields: [bannedById], references: [id])
  user       User      @relation("UserBans", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt(sort: Desc)])
}

model CommunitySettings {
  id                   String   @id @default("singleton")
  communityName        String   @default("Community")
  communityDescription String?
  communityLogo        String?
  welcomeMessage       String?
  registrationOpen     Boolean  @default(true)
  postingEnabled       Boolean  @default(true)
  commentsEnabled      Boolean  @default(true)
  updatedAt            DateTime @updatedAt
  logoSize             Int      @default(36)
  landingPriceUsd      Int      @default(89)
  landingPriceEur      Int      @default(89)
  landingVideoUrls     Json     @default("[]")
  landingBenefits      Json     @default("[]")
  landingTestimonials  Json     @default("[]")
  landingTranslations  Json     @default("{}")
  landingHeadline      String?
  landingSubheadline   String?
  landingDescription   String?
  landingCtaText       String?  @db.VarChar(100)
  communityLogoDark    String?
  sidebarBannerImage   String?
  sidebarBannerUrl     String?
  sidebarBannerEnabled Boolean  @default(false)
  classroomVideoUrls   Json     @default("{}")
  // CR9 F1: Landing page social-proof toggles (default OFF so empty community isn't embarrassing)
  landingShowAvatarMosaic Boolean @default(false)
  landingShowMemberCount  Boolean @default(false)
  landingShowRecentPosts  Boolean @default(false)
  // Gamification config (editable from /admin/gamify)
  gamifyPointsPost       Int    @default(5)
  gamifyPointsComment    Int    @default(2)
  gamifyPointsLike       Int    @default(1)
  gamifyPointsLesson     Int    @default(10)
  gamifyLevelThresholds  String @default("0,50,120,210,320,450,600,770,960,1170")
}

model Membership {
  id                   String           @id @default(cuid())
  userId               String           @unique
  status               MembershipStatus @default(ACTIVE)
  planName             String           @default("Community Membership")
  paidAt               DateTime         @default(now())
  expiresAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Translation {
  id                String   @id @default(cuid())
  entityType        String
  entityId          String
  fieldName         String
  sourceLanguage    String
  sourceHash        String
  targetLanguage    String
  translatedContent String
  modelProvider     String
  modelVersion      String
  confidenceScore   Float?
  createdAt         DateTime @default(now())

  @@unique([entityType, entityId, fieldName, targetLanguage])
  @@index([entityType, entityId, targetLanguage])
  @@index([sourceHash, targetLanguage])
}

model TranslationUsage {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  charCount    Int
  sourceLang   String
  targetLang   String
  fromCache    Boolean  @default(false)
  cacheTier    String?  // 'lru' | 'db' | 'miss' — null for pre-existing rows
  costEstimate Float    @default(0)

  @@index([date])
  @@index([sourceLang, targetLang])
  @@index([cacheTier, date])
  @@index([date, fromCache])
}

model TranslationConfig {
  id                    String    @id @default("singleton")
  dailyCharBudget       Int       @default(50000)
  killSwitchActive      Boolean   @default(false)
  killSwitchActivatedAt DateTime?
  budgetAlertSentAt     DateTime?
  updatedAt             DateTime  @updatedAt
}

model ApiUsage {
  id        String   @id @default(cuid())
  service   String   // "deepl", "gemini", "resend", "stripe", "giphy", "supabase"
  action    String   // "translate", "send_email", "search_gif", "checkout", etc.
  units     Int      @default(1)
  unitType  String   // "characters", "tokens", "emails", "requests"
  cost      Float    @default(0)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([service, createdAt])
  @@index([createdAt])
}

model KanbanCard {
  id          String       @id @default(cuid())
  title       String       @db.VarChar(200)
  description String?
  imageUrl    String?
  status      KanbanStatus @default(TODO)
  position    Int          @default(0)
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @default(now()) @updatedAt @db.Timestamptz(3)

  @@index([status, position])
  @@index([createdById])
}

model DevTrackerCard {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  branchName   String    @unique
  column       String    @default("active")
  priority     String?
  assignee     String?
  platformTag  String?
  flagged      Boolean   @default(false)
  notes        String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([column])
  @@index([flagged])
}

model DevTrackerResource {
  id          String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  type        DevResourceType
  title       String          @db.VarChar(200)
  content     String
  starred     Boolean         @default(false)
  useCount    Int             @default(0)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  fileUrl     String?
  fileName    String?         @db.VarChar(255)
  fileSize    Int?
  mimeType    String?         @db.VarChar(100)
  readme      String?
  media       Json            @default("[]")
  createdBy   User            @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([starred])
  @@index([createdById])
}

model LaunchChecklistItem {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  category    String
  label       String   @db.VarChar(300)
  checked     Boolean  @default(false)
  autoChecked Boolean  @default(false)
  blocker     Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  key         String?

  @@index([category])
  @@index([blocker])
}

model AiTool {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(200)
  url          String   @db.VarChar(500)
  description  String?
  active       Boolean  @default(true)
  openInNewTab Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, position])
}

model AdminTool {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(200)
  url         String   @db.VarChar(500)
  description String?
  createdAt   DateTime @default(now())
}

model FeedReport {
  id             String   @id
  userId         String
  videoId        String
  jobDescription String
  language       String
  reportContent  String
  createdAt      DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

model FeedVideo {
  id          String   @id
  youtubeUrl  String
  youtubeId   String
  title       String   @db.VarChar(300)
  description String?
  addedById   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum RecurrenceType {
  NONE
  WEEKLY
  MONTHLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum KanbanStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum DevResourceType {
  PROMPT
  LINK
  NOTE
  FILE
}

enum FeatureIdeaStatus {
  NEW
  UNDER_REVIEW
  APPROVED
  IN_PROGRESS
  COMPLETED
  DECLINED
}

// ─── Translation System ─────────────────────────────────────────────────────

/// Cached translations to minimise DeepL API calls (Part D / G)
model TranslationCache {
  id             String    @id @default(cuid())
  sourceTextHash String
  sourceLocale   String    @db.VarChar(10)
  targetLocale   String    @db.VarChar(10)
  translatedText String
  glossaryId     String?
  contextHash    String?
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?

  @@unique([sourceTextHash, sourceLocale, targetLocale, glossaryId])
  @@index([sourceLocale, targetLocale])
  @@index([expiresAt])
}

/// "Do Not Translate" blacklist – terms that stay in original language (Part B1)
model TranslationBlacklist {
  id        String   @id @default(cuid())
  term      String   @unique
  category  String
  note      String?
  addedById String?
  addedBy   User?    @relation("BlacklistAddedBy", fields: [addedById], references: [id])
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

/// Controlled translation pairs synced to DeepL Glossary API (Part B2)
model TranslationGlossaryEntry {
  id              String   @id @default(cuid())
  sourceTerm      String
  targetTerm      String
  sourceLocale    String   @db.VarChar(10)
  targetLocale    String   @db.VarChar(10)
  domain          String?
  approvedById    String?
  approvedBy      User?    @relation("GlossaryApprovedBy", fields: [approvedById], references: [id])
  deeplGlossaryId String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([sourceTerm, sourceLocale, targetLocale])
  @@index([sourceLocale, targetLocale])
  @@index([domain])
  @@index([isActive])
}

/// Version log for glossary changes (Part E2)
model GlossaryChangeLog {
  id          String   @id @default(cuid())
  entryId     String?
  action      String   // "create" | "update" | "delete" | "sync"
  changedById String
  changedBy   User     @relation("GlossaryChangeBy", fields: [changedById], references: [id])
  oldValue    Json?
  newValue    Json?
  createdAt   DateTime @default(now())

  @@index([entryId])
  @@index([createdAt(sort: Desc)])
}

/// User-submitted translation correction proposals (Part C / F2)
model TranslationFeedback {
  id                  String   @id @default(cuid())
  postId              String?
  commentId           String?
  userId              String
  user                User     @relation("TranslationFeedbackUser", fields: [userId], references: [id])
  sourceLocale        String   @db.VarChar(10)
  targetLocale        String   @db.VarChar(10)
  originalText        String
  translatedText      String
  suggestedCorrection String?
  feedbackType        String   // 'incorrect_term' | 'wrong_context' | 'grammar' | 'missing_nuance' | 'other'
  status              String   @default("pending") // 'pending' | 'reviewing' | 'resolved' | 'rejected'
  resolvedById        String?
  resolvedBy          User?    @relation("FeedbackResolvedBy", fields: [resolvedById], references: [id])
  resolvedAt          DateTime?
  adminNote           String?
  createdAt           DateTime @default(now())

  @@index([status])
  @@index([userId])
  @@index([sourceLocale, targetLocale])
  @@index([createdAt(sort: Desc)])
}

/// Per-section translation rules (Part E3)
model TranslationRule {
  id                    String   @id @default(cuid())
  sectionName           String   @unique
  formality             String   @default("more") // 'more' | 'less' | 'default'
  defaultPreviewLocale  String   @default("en") @db.VarChar(10)
  activeGlossaryDomain  String?
  autoTranslate         Boolean  @default(true)
  qualityThreshold      Float    @default(0.7)
  cacheTtlDays          Int      @default(30)
  contextDepth          Int      @default(2)
  isActive              Boolean  @default(true)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([sectionName])
}

/// Language pair quality matrix (Part F5)
model LanguagePairQuality {
  id           String   @id @default(cuid())
  sourceLocale String   @db.VarChar(10)
  targetLocale String   @db.VarChar(10)
  quality      String   @default("B") // 'A' | 'B' | 'C' | 'D'
  usePivot     Boolean  @default(false)
  pivotLocale  String?  @db.VarChar(10)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([sourceLocale, targetLocale])
}

model FeatureIdea {
  id          String             @id @default(cuid())
  title       String             @db.VarChar(200)
  description String             @db.Text
  status      FeatureIdeaStatus  @default(NEW)
  priority    String?
  tags        String[]           @default([])
  authorId    String
  author      User               @relation("FeatureIdeaAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  upvotes     FeatureIdeaUpvote[]
  comments    FeatureIdeaComment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

model FeatureIdeaUpvote {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("FeatureIdeaUpvotes", fields: [userId], references: [id], onDelete: Cascade)
  ideaId    String
  idea      FeatureIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, ideaId])
  @@index([ideaId])
  @@index([userId])
}

model FeatureIdeaComment {
  id        String      @id @default(cuid())
  content   String      @db.Text
  authorId  String
  author    User        @relation("FeatureIdeaComments", fields: [authorId], references: [id], onDelete: Cascade)
  ideaId    String
  idea      FeatureIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([ideaId])
  @@index([authorId])
}

/// Dynamically toggled active languages for the platform.
/// English (code: 'en') is always active and cannot be deactivated.
model LanguageConfig {
  id        String   @id @default(cuid())
  code      String   @unique @db.VarChar(10)
  name      String
  flag      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

enum NotificationType {
  COMMENT
  LIKE
  MENTION
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  recipientId String
  actorId     String
  postId      String?
  commentId   String?
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  recipient   User     @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor       User     @relation("NotificationActor", fields: [actorId], references: [id], onDelete: Cascade)
  post        Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment     Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@index([recipientId, isRead, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
}

enum BadgeType {
  FIRST_POST
  CONVERSATIONALIST
  POPULAR
  SCHOLAR
  LEVEL_5
  TOP_10
  STREAK_7
  WELCOME
}

/// Badge presentation + grant-condition metadata.
///
/// Kept separate from `Badge` (the user-to-badge join) so admins can rename,
/// recolor, or replace icons without touching award logic — the `BadgeType`
/// enum keeps compile-time safety on auto-award rules.
///
/// `condition = "auto"` — awarded by `checkAndAwardBadgesInternal` against
///   a fixed computed rule keyed by `type`.
/// `condition = "manual"` — only granted via admin UI. Has a `customDefinitionId`
///   (not a BadgeType) and is stored on Badge via the FK.
model BadgeDefinition {
  id          String   @id @default(cuid())
  /// One of the system-seeded 8 BadgeType values, or null for admin-authored custom badges.
  /// Partial unique (non-null only) enforced via raw SQL index, since @@unique would treat NULL as unique-per-row.
  type        BadgeType?
  /// Admin-chosen slug (unique) — used for URL params + ordering stability.
  key         String   @unique
  label       String
  description String
  emoji       String
  /// Optional uploaded icon URL (Supabase Storage). Falls back to emoji when null.
  iconUrl     String?
  /// "auto" (BadgeType-keyed rule) or "manual" (admin-granted only)
  condition   String   @default("auto")
  /// Accent color (hex); defaults to brand red.
  colorHex    String   @default("#D94A4A")
  sortOrder   Int      @default(100)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  badges      Badge[]

  @@index([type])
  @@index([condition])
  @@index([sortOrder])
}

model Badge {
  id                  String           @id @default(cuid())
  userId              String
  /// BadgeType for system-seeded badges (auto-awarded). NULL for custom admin-authored badges.
  type                BadgeType?
  /// FK to BadgeDefinition for custom badges. NULL for system badges (which key by `type`).
  /// App-layer invariant: exactly one of {type, customDefinitionId} is non-null.
  customDefinitionId  String?
  earnedAt            DateTime         @default(now())
  user                User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  customDefinition    BadgeDefinition? @relation(fields: [customDefinitionId], references: [id], onDelete: Cascade)

  @@unique([userId, type])
  @@unique([userId, customDefinitionId])
  @@index([userId])
  @@index([customDefinitionId])
}
