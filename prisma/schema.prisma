generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String                   @id @default(cuid())
  email            String                   @unique
  name             String?
  image            String?
  hashedPassword   String?
  bio              String?                  @db.VarChar(500)
  points           Int                      @default(0)
  level            Int                      @default(1)
  role             String                   @default("member")
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt
  searchVector     Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(name, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, (COALESCE(bio, ''::character varying))::text), 'B'::\"char\"))"))
  languageCode     String?                  @default("en") @db.VarChar(10)
  jobDescription   String?                  @db.VarChar(100)
  stripeCustomerId String?                  @unique
  auditLogs        AuditLog[]
  bannedUsers      Ban[]                    @relation("BannedByUser")
  bans             Ban[]                    @relation("UserBans")
  comments         Comment[]
  commentLikes     CommentLike[]
  devResources     DevTrackerResource[]
  enrollments      Enrollment[]
  events           Event[]
  lessonProgress   LessonProgress[]
  membership       Membership?
  pointsEvents     PointsEvent[]
  posts              Post[]
  postLikes          PostLike[]
  featureIdeas       FeatureIdea[]        @relation("FeatureIdeaAuthor")
  featureIdeaUpvotes FeatureIdeaUpvote[]  @relation("FeatureIdeaUpvotes")
  featureIdeaComments FeatureIdeaComment[] @relation("FeatureIdeaComments")
  kanbanCards        KanbanCard[]

  @@index([email])
  @@index([points])
  @@index([searchVector], type: Gin)
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  posts     Post[]
}

model Post {
  id           String                   @id @default(cuid())
  content      Json
  plainText    String?
  embeds       Json                     @default("[]")
  authorId     String
  categoryId   String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  searchVector Unsupported("tsvector")? @default(dbgenerated("to_tsvector('english'::regconfig, COALESCE(\"plainText\", ''::text))"))
  title        String?                  @db.VarChar(200)
  languageCode String?                  @db.VarChar(10)
  contentHash  String?                  @db.VarChar(64)
  gifs         Json                     @default("[]")
  comments     Comment[]
  author       User                     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category     Category?                @relation(fields: [categoryId], references: [id])
  likes        PostLike[]

  @@index([authorId])
  @@index([categoryId])
  @@index([createdAt(sort: Desc)])
  @@index([searchVector], type: Gin)
}

model Comment {
  id           String        @id @default(cuid())
  content      String        @db.VarChar(2000)
  authorId     String
  postId       String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  contentHash  String?
  languageCode String?
  author       User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  post         Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  likes        CommentLike[]

  @@index([postId])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

model PostLike {
  id        String   @id @default(cuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([postId])
  @@index([userId])
}

model CommentLike {
  id        String   @id @default(cuid())
  userId    String
  commentId String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
  @@index([commentId])
  @@index([userId])
}

model PasswordResetToken {
  id      String   @id @default(cuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
  @@index([email])
  @@index([token])
}

model Course {
  id           String                   @id @default(cuid())
  title        String
  description  String?
  status       CourseStatus             @default(DRAFT)
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  searchVector Unsupported("tsvector")? @default(dbgenerated("(setweight(to_tsvector('english'::regconfig, COALESCE(title, ''::text)), 'A'::\"char\") || setweight(to_tsvector('english'::regconfig, COALESCE(description, ''::text)), 'B'::\"char\"))"))
  languageCode String?                  @db.VarChar(10)
  contentHash  String?                  @db.VarChar(64)
  coverImage   String?
  enrollments  Enrollment[]
  modules      Module[]

  @@index([status])
  @@index([searchVector], type: Gin)
}

model Module {
  id        String   @id @default(cuid())
  title     String
  position  Int
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lessons   Lesson[]
  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([courseId, position])
}

model Lesson {
  id           String           @id @default(cuid())
  title        String
  position     Int
  status       LessonStatus     @default(DRAFT)
  videoUrl     String?
  content      Json
  moduleId     String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  languageCode String?          @db.VarChar(10)
  contentHash  String?          @db.VarChar(64)
  attachments  Attachment[]
  module       Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress     LessonProgress[]

  @@index([moduleId])
  @@index([moduleId, position])
}

model Attachment {
  id        String   @id @default(cuid())
  name      String
  url       String
  size      Int
  mimeType  String
  lessonId  String
  createdAt DateTime @default(now())
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  courseId   String
  enrolledAt DateTime @default(now())
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
}

model LessonProgress {
  id          String   @id @default(cuid())
  userId      String
  lessonId    String
  completedAt DateTime @default(now())
  lesson      Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@index([userId])
  @@index([lessonId])
}

model Event {
  id            String         @id @default(cuid())
  title         String         @db.VarChar(200)
  description   Json
  startTime     DateTime       @db.Timestamptz(3)
  endTime       DateTime       @db.Timestamptz(3)
  location      String?        @db.VarChar(200)
  locationUrl   String?        @db.VarChar(500)
  coverImage    String?
  recurrence    RecurrenceType @default(NONE)
  recurrenceEnd DateTime?      @db.Timestamptz(3)
  createdById   String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  languageCode  String?        @db.VarChar(10)
  contentHash   String?        @db.VarChar(64)
  createdBy     User           @relation(fields: [createdById], references: [id])

  @@index([startTime])
  @@index([createdById])
}

model PointsEvent {
  id        String   @id @default(cuid())
  userId    String
  amount    Int
  action    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Ban {
  id         String    @id @default(cuid())
  userId     String
  reason     String    @db.VarChar(500)
  expiresAt  DateTime? @db.Timestamptz(3)
  bannedById String
  createdAt  DateTime  @default(now())
  bannedBy   User      @relation("BannedByUser", fields: [bannedById], references: [id])
  user       User      @relation("UserBans", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String
  targetId   String?
  targetType String?
  details    Json?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([action])
  @@index([targetId])
  @@index([createdAt(sort: Desc)])
}

model CommunitySettings {
  id                   String   @id @default("singleton")
  communityName        String   @default("Community")
  communityDescription String?
  communityLogo        String?
  welcomeMessage       String?
  registrationOpen     Boolean  @default(true)
  postingEnabled       Boolean  @default(true)
  commentsEnabled      Boolean  @default(true)
  updatedAt            DateTime @updatedAt
  logoSize             Int      @default(36)
  landingPriceUsd      Int      @default(89)
  landingPriceEur      Int      @default(89)
  landingVideoUrls     Json     @default("[]")
  landingBenefits      Json     @default("[]")
  landingTestimonials  Json     @default("[]")
  landingTranslations  Json     @default("{}")
  landingHeadline      String?
  landingSubheadline   String?
  landingDescription   String?
  landingCtaText       String?  @db.VarChar(100)
  communityLogoDark    String?
  sidebarBannerImage   String?
  sidebarBannerUrl     String?
  sidebarBannerEnabled Boolean  @default(false)
  classroomVideoUrls   Json     @default("{}")
}

model Membership {
  id                   String           @id @default(cuid())
  userId               String           @unique
  status               MembershipStatus @default(ACTIVE)
  planName             String           @default("Community Membership")
  paidAt               DateTime         @default(now())
  expiresAt            DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  stripeCustomerId     String?          @unique
  stripeSubscriptionId String?          @unique
  stripePriceId        String?
  user                 User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
}

model Translation {
  id                String   @id @default(cuid())
  entityType        String
  entityId          String
  fieldName         String
  sourceLanguage    String
  sourceHash        String
  targetLanguage    String
  translatedContent String
  modelProvider     String
  modelVersion      String
  confidenceScore   Float?
  createdAt         DateTime @default(now())

  @@unique([entityType, entityId, fieldName, targetLanguage])
  @@index([entityType, entityId, targetLanguage])
}

model TranslationUsage {
  id           String   @id @default(cuid())
  date         DateTime @default(now())
  charCount    Int
  sourceLang   String
  targetLang   String
  fromCache    Boolean  @default(false)
  costEstimate Float    @default(0)

  @@index([date])
  @@index([sourceLang, targetLang])
}

model ApiUsage {
  id        String   @id @default(cuid())
  service   String   // "deepl", "gemini", "resend", "stripe", "giphy", "supabase"
  action    String   // "translate", "send_email", "search_gif", "checkout", etc.
  units     Int      @default(1)
  unitType  String   // "characters", "tokens", "emails", "requests"
  cost      Float    @default(0)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([service, createdAt])
  @@index([createdAt])
}

model KanbanCard {
  id          String       @id @default(cuid())
  title       String       @db.VarChar(200)
  description String?
  imageUrl    String?
  status      KanbanStatus @default(TODO)
  position    Int          @default(0)
  createdById String
  createdBy   User         @relation(fields: [createdById], references: [id], onDelete: Cascade)
  createdAt   DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime     @default(now()) @updatedAt @db.Timestamptz(3)

  @@index([status, position])
  @@index([createdById])
}

model DevTrackerCard {
  id           String    @id @default(dbgenerated("(gen_random_uuid())::text"))
  branchName   String    @unique
  column       String    @default("active")
  priority     String?
  assignee     String?
  platformTag  String?
  flagged      Boolean   @default(false)
  notes        String?
  lastSyncedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([column])
  @@index([flagged])
}

model DevTrackerResource {
  id          String          @id @default(dbgenerated("(gen_random_uuid())::text"))
  type        DevResourceType
  title       String          @db.VarChar(200)
  content     String
  starred     Boolean         @default(false)
  useCount    Int             @default(0)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt
  fileUrl     String?
  fileName    String?         @db.VarChar(255)
  fileSize    Int?
  mimeType    String?         @db.VarChar(100)
  createdBy   User            @relation(fields: [createdById], references: [id])

  @@index([type])
  @@index([starred])
  @@index([createdById])
}

model LaunchChecklistItem {
  id          String   @id @default(dbgenerated("(gen_random_uuid())::text"))
  category    String
  label       String   @db.VarChar(300)
  checked     Boolean  @default(false)
  autoChecked Boolean  @default(false)
  blocker     Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt
  key         String?

  @@index([category])
  @@index([blocker])
}

model AiTool {
  id           String   @id @default(cuid())
  name         String   @db.VarChar(200)
  url          String   @db.VarChar(500)
  description  String?
  active       Boolean  @default(true)
  openInNewTab Boolean  @default(true)
  position     Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, position])
}

model FeedReport {
  id             String   @id
  userId         String
  videoId        String
  jobDescription String
  language       String
  reportContent  String
  createdAt      DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId])
  @@index([videoId])
}

model FeedVideo {
  id          String   @id
  youtubeUrl  String
  youtubeId   String
  title       String   @db.VarChar(300)
  description String?
  addedById   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
}

enum CourseStatus {
  DRAFT
  PUBLISHED
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

enum RecurrenceType {
  NONE
  WEEKLY
  MONTHLY
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum KanbanStatus {
  TODO
  IN_PROGRESS
  DONE
}

enum DevResourceType {
  PROMPT
  LINK
  NOTE
  FILE
}

enum FeatureIdeaStatus {
  NEW
  UNDER_REVIEW
  APPROVED
  IN_PROGRESS
  COMPLETED
  DECLINED
}

model FeatureIdea {
  id          String             @id @default(cuid())
  title       String             @db.VarChar(200)
  description String             @db.Text
  status      FeatureIdeaStatus  @default(NEW)
  priority    String?
  tags        String[]           @default([])
  authorId    String
  author      User               @relation("FeatureIdeaAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  upvotes     FeatureIdeaUpvote[]
  comments    FeatureIdeaComment[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

model FeatureIdeaUpvote {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation("FeatureIdeaUpvotes", fields: [userId], references: [id], onDelete: Cascade)
  ideaId    String
  idea      FeatureIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@unique([userId, ideaId])
  @@index([ideaId])
  @@index([userId])
}

model FeatureIdeaComment {
  id        String      @id @default(cuid())
  content   String      @db.Text
  authorId  String
  author    User        @relation("FeatureIdeaComments", fields: [authorId], references: [id], onDelete: Cascade)
  ideaId    String
  idea      FeatureIdea @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())

  @@index([ideaId])
  @@index([authorId])
}
